# Copy this file to .env.production and fill in real values.
# Next.js automatically loads .env.production during "npm run build" and "npm start".
# Generate NEXTAUTH_SECRET: openssl rand -base64 32

# Django backend URL (accessible from the browser — use your server's IP/domain)
NEXT_PUBLIC_Django_API_URL=http://your-server-ip:8000

# NextAuth
NEXTAUTH_URL=http://your-server-ip:3000
NEXTAUTH_SECRET=CHANGE-ME-generate-a-real-secret

# Must match SCANNER_API_KEY in backend .env.production
NEXT_PUBLIC_API_KEY=CHANGE-ME-same-as-backend-SCANNER_API_KEY
